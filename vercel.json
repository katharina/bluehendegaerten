{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/plants/all", "dest": "/plants/all.html" },
    { "src": "/beobachtungen(.*)", "dest": "/beobachtungen/index.html" },
    { "src": "/(.*)", "dest": "/garden.html" }
  ]
}
